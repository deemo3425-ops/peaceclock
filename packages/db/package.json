{
  "name": "@peaceclock/db",
  "version": "0.0.1",
  "description": "PeaceClock database schema and utilities",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "migrate": "drizzle-kit migrate",
    "migrate:generate": "drizzle-kit generate:pg",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run --exclude '**/integration.test.ts'",
    "test:integration": "vitest run src/__tests__/integration.test.ts",
    "db:setup:test": "node src/__tests__/fixtures/seed.mjs --schema-only",
    "db:seed:test": "node src/__tests__/fixtures/seed.mjs --seed-only"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "@peaceclock/api-types": "workspace:*",
    "@peaceclock/count-engine": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}
