{
  "name": "@peaceclock/mobile",
  "version": "0.0.1",
  "private": true,
  "description": "PeaceClock native app (Expo / React Native)",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "eas:build:dev": "eas build --profile development --platform all",
    "eas:build:preview": "eas build --profile preview --platform all",
    "eas:build:prod": "eas build --profile production --platform all",
    "eas:submit": "eas submit --profile production --platform all --latest"
  },
  "dependencies": {
    "@maplibre/maplibre-react-native": "10.4.2",
    "@peaceclock/api-types": "workspace:*",
    "@peaceclock/count-engine": "workspace:*",
    "@react-native-community/slider": "4.5.5",
    "@react-navigation/bottom-tabs": "^7.2.0",
    "@react-navigation/native": "^7.0.14",
    "@react-native-async-storage/async-storage": "1.23.1",
    "expo": "~52.0.46",
    "expo-linking": "~7.0.5",
    "expo-status-bar": "~2.0.1",
    "react": "18.3.1",
    "react-native": "0.76.9",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0"
  },
  "devDependencies": {
    "@types/react": "~18.3.12",
    "typescript": "^5.3.0"
  }
}