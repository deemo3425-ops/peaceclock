# Copy to apps/web/.env.local and fill DATABASE_URL (Neon dev branch or local Postgres).
# Testing phase: $0 — use SQL fixture seed (pnpm dev:bootstrap), not pnpm db:seed.

DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/peaceclock?sslmode=require

# Placeholders satisfy validateEnv(); corroboration/ingest will fail without real keys.
ANTHROPIC_API_KEY=fake-local-dev
VOYAGE_API_KEY=fake-local-dev

NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional — omit for OSM raster fallback in dev
# NEXT_PUBLIC_MAP_STYLE_URL=

# Optional — unset leaves cron/audit routes open locally (see apps/web/lib/env.ts)
# CRON_SECRET=
# AUDIT_SECRET=