# Database
DATABASE_URL=postgresql://user:password@db.neon.tech/peaceclock

# AI / LLMs
ANTHROPIC_API_KEY=sk-ant-...
VOYAGE_API_KEY=pa-...

# Public site (canonical URLs, sitemap, OG metadata)
NEXT_PUBLIC_SITE_URL=https://peaceclock.org

# App store links (set after M6 launch; omit for "coming soon" badges)
# NEXT_PUBLIC_APP_STORE_URL=
# NEXT_PUBLIC_PLAY_STORE_URL=
# NEXT_PUBLIC_MAC_STORE_URL=

# Analytics (optional)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Route protection (required in production — NODE_ENV=production)
CRON_SECRET=generate-a-long-random-string
AUDIT_SECRET=generate-a-long-random-string

# Map tiles (optional — omit in dev to use keyless OSM raster fallback; see apps/web/lib/map.ts)
# Production: MapTiler vector style (EDD §14). Key at https://cloud.maptiler.com/
NEXT_PUBLIC_MAP_STYLE_URL=https://api.maptiler.com/maps/streets-v2/style.json?key=YOUR_MAPTILER_KEY
